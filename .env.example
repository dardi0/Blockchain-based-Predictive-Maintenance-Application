# ============================================
# PDM Project - Environment Variables Template
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file!
# ============================================

# Network Selection
ACTIVE_NETWORK=ZKSYNC_ERA

# ================== PRIVATE KEYS ==================
# WARNING: Keep these secret! Never share or commit!
# Generate new keys for production
ENGINEER_PRIVATE_KEY=your_engineer_private_key_here
OPERATOR_PRIVATE_KEY=your_operator_private_key_here
MANAGER_PRIVATE_KEY=your_manager_private_key_here
CONTRACT_OWNER_PRIVATE_KEY=your_contract_owner_private_key_here

# ================== RPC URLS ==================
ZKSYNC_ERA_RPC_URL=https://sepolia.era.zksync.dev

# Optional: API Keys
ZKSYNC_ETHERSCAN_API_KEY=your_zksync_etherscan_api_key

# ================== PERFORMANCE ==================
GAS_LIMIT_MULTIPLIER=1.2
MAX_FEE_PER_GAS=1000000000
MAX_PRIORITY_FEE_PER_GAS=100000000

# ================== SECURITY ==================
ENABLE_DEBUG_MODE=false
LOG_LEVEL=INFO
PYTHONUTF8=1

# ================== ROLE ADDRESSES ==================
# These are public addresses, safe to share
CONTRACT_OWNER_ADDRESS=0xYourContractOwnerAddress
MANAGER_ADDRESS=0xYourManagerAddress
ENGINEER_ADDRESS=0xYourEngineerAddress
OPERATOR_ADDRESS=0xYourOperatorAddress
ADMIN_ADDRESS=0xYourAdminAddress

# ================== API KEYS ==================
# Keep these secret!
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ================== DEPLOYED CONTRACTS ==================
PDM_SYSTEM_ADDRESS=0xYourPDMSystemAddress
ACCESS_CONTROL_ADDRESS=0xYourAccessControlAddress
VERIFIER_ADDRESS=0xYourVerifierAddress
NEXT_PUBLIC_CONTRACT_ADDRESS=0xYourContractAddress

# ================== CHAINLINK ==================
# Create subscription at: https://functions.chain.link/zksync-sepolia
CHAINLINK_SUBSCRIPTION_ID=your_subscription_id
# Set after deploying BackendOracleConsumer (deploy/deploy-chainlink.js)
BACKEND_ORACLE_ADDRESS=0xYourBackendOracleAddress
# Set after deploying ChainlinkPdMAutomation — loaded automatically from chainlink_deployment_info.json if present
CHAINLINK_AUTOMATION_ADDRESS=0xYourChainlinkAutomationAddress
CHAINLINK_AUTOMATION_PRIVATE_KEY=your_automation_oracle_private_key
# REQUIRED: generate a strong random key (e.g. openssl rand -hex 32) — protects write automation endpoints
CHAINLINK_AUTOMATION_API_KEY=your_secure_random_api_key_here

# ================== API SERVER ==================
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ================== AUTOMATION ==================
AUTOMATION_LISTENER_ENABLED=true
POLL_INTERVAL=30
